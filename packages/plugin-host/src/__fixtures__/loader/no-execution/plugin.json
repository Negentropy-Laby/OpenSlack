{
  "schema": "openslack.plugin.v1",
  "id": "no-execution",
  "version": "1.0.0",
  "name": "No execution fixture",
  "requires": {
    "openslack": ">=0.1.0 <1.0.0"
  },
  "gate": {
    "mode": "SHADOW",
    "gateId": "host.read-only"
  },
  "capabilities": ["host.actions.read"],
  "contributes": [
    {
      "kind": "action_alias",
      "id": "status",
      "target": {
        "kind": "host_action",
        "id": "status.show"
      }
    }
  ]
}
