{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openslack.dev/schemas/evolution-task.schema.json",
  "title": "OpenSlack Evolution Task",
  "type": "object",
  "required": ["schema", "id", "title", "status", "created_at", "created_by", "source", "problem", "hypothesis", "risk", "constraints", "validation", "output_contract"],
  "properties": {
    "schema": { "type": "string", "const": "openslack.evolution_task.v1" },
    "id": { "type": "string", "pattern": "^EVOL-\\d{4}-\\d{6}$" },
    "title": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["observed", "diagnosed", "proposed", "planned", "claimable", "claimed", "implementing", "validating", "validated", "reviewing", "approved", "merge_queued", "merged", "canary_monitoring", "stable", "learned", "validation_failed", "rejected", "regression_detected", "rollback_proposed", "rolled_back"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string" },
    "depends_on": { "type": "array", "items": { "type": "string" }, "description": "EVOL task IDs this task depends on" },
    "source": {
      "type": "object",
      "required": ["type", "evidence"],
      "properties": {
        "type": { "type": "string", "enum": ["post_merge_monitor", "ci_failure", "test_flake", "github_issue", "pr_review", "user_feedback", "agent_failure", "task_timeout", "cost_anomaly", "schema_validation_failure", "workspace_drift", "security_scan", "chat_adapter_failure"] },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "problem": {
      "type": "object",
      "required": ["summary", "affected_modules"],
      "properties": {
        "summary": { "type": "string" },
        "affected_modules": { "type": "array", "items": { "type": "string" } }
      }
    },
    "hypothesis": {
      "type": "object",
      "required": ["statement", "expected_metric_change"],
      "properties": {
        "statement": { "type": "string" },
        "expected_metric_change": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "risk": {
      "type": "object",
      "required": ["level", "reasons", "protected_paths_touched", "human_approval_required"],
      "properties": {
        "level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "protected_paths_touched": { "type": "boolean" },
        "human_approval_required": { "type": "boolean" }
      }
    },
    "constraints": {
      "type": "object",
      "required": ["allowed_paths", "forbidden_paths"],
      "properties": {
        "allowed_paths": { "type": "array", "items": { "type": "string" } },
        "forbidden_paths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "validation": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": { "type": "array", "items": { "type": "string" } }
      }
    },
    "output_contract": {
      "type": "object",
      "required": ["must_include"],
      "properties": {
        "must_include": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
