{
  "schema": "openslack.plugin.v1",
  "id": "approve-action",
  "version": "1.0.0",
  "name": "Approval fixture",
  "requires": { "openslack": ">=0.1.0 <1.0.0" },
  "gate": { "mode": "ENFORCE", "gateId": "host.read-only" },
  "capabilities": ["host.actions.read"],
  "contributes": [
    {
      "kind": "action_alias",
      "id": "approve",
      "target": { "kind": "host_action", "id": "pull-request.approve" }
    }
  ]
}
