{
  "schema": "openslack.plugin.v1",
  "id": "approval-capability",
  "version": "1.0.0",
  "name": "Approval capability fixture",
  "requires": { "openslack": ">=0.1.0 <1.0.0" },
  "gate": { "mode": "SHADOW", "gateId": "host.read-only" },
  "capabilities": ["github.pull_requests.approve"],
  "contributes": [
    {
      "kind": "action_alias",
      "id": "status",
      "target": { "kind": "host_action", "id": "github.metrics" }
    }
  ]
}
