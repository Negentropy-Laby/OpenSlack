{
  "name": "@openslack/plugin-testkit",
  "version": "0.2.0",
  "description": "OpenSlack plugin testkit — deterministic checks for declarative plugin manifests",
  "keywords": [
    "openslack",
    "agent-collaboration",
    "github",
    "llm-agents",
    "testkit"
  ],
  "homepage": "https://github.com/Negentropy-Laby/OpenSlack/tree/main/packages/plugin-testkit",
  "bugs": {
    "url": "https://github.com/Negentropy-Laby/OpenSlack/issues"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Negentropy-Laby/OpenSlack.git",
    "directory": "packages/plugin-testkit"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@openslack/plugin-api": "workspace:*"
  },
  "devDependencies": {
    "@openslack/plugin-host": "workspace:*",
    "yaml": "^2.7.0"
  }
}
