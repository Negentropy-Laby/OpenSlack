{
  "name": "@openslack/plugin-api",
  "version": "0.2.0",
  "description": "OpenSlack public plugin contract — manifest schema, capability IDs, and host policy types",
  "keywords": [
    "openslack",
    "agent-collaboration",
    "github",
    "llm-agents",
    "plugin-api"
  ],
  "homepage": "https://github.com/Negentropy-Laby/OpenSlack/tree/main/packages/plugin-api",
  "bugs": {
    "url": "https://github.com/Negentropy-Laby/OpenSlack/issues"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./plugin-manifest.schema.json": "./dist/plugin-manifest.schema.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Negentropy-Laby/OpenSlack.git",
    "directory": "packages/plugin-api"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
