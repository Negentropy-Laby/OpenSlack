{
  "schema": "openslack.plugin.v1",
  "id": "executable-plugin",
  "version": "1.0.0",
  "name": "Executable plugin",
  "requires": { "openslack": ">=0.2.0" },
  "gate": { "mode": "SHADOW", "gateId": "host.read-only" },
  "capabilities": ["host.actions.read"],
  "contributes": [
    {
      "kind": "action_alias",
      "id": "status",
      "target": { "kind": "host_action", "id": "status.show" }
    }
  ],
  "entry": "./index.js"
}
