{
  "schema": "openslack.plugin.v1",
  "id": "custom-code",
  "version": "1.0.0",
  "name": "Custom code",
  "requires": { "openslack": ">=0.2.0" },
  "gate": { "mode": "SHADOW", "gateId": "host.read-only" },
  "capabilities": ["host.actions.read"],
  "contributes": [
    {
      "kind": "prms_evaluator",
      "id": "approve",
      "target": { "kind": "host_action", "id": "pr.review" }
    }
  ]
}
