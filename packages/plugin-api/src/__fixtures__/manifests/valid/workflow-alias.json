{
  "schema": "openslack.plugin.v1",
  "id": "profile-reader",
  "version": "1.2.3-beta.1+build.7",
  "name": "Profile reader",
  "requires": { "openslack": "^0.2.0" },
  "gate": { "mode": "ENFORCE", "gateId": "workflow.read-only" },
  "capabilities": ["host.workflows.read", "workspace.read"],
  "contributes": [
    {
      "kind": "workflow_alias",
      "id": "profile-status",
      "title": "Profile status",
      "target": { "kind": "host_workflow", "id": "profile-sync.status" }
    }
  ]
}
