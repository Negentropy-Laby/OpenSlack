{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openslack.dev/schemas/github-watch-v2.schema.json",
  "title": "GitHubWatchConfigV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "repositories"],
  "properties": {
    "schema": { "const": "openslack.github_watch.v2" },
    "notification_service": { "$ref": "#/$defs/notificationService" },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/repository" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "repositories": {
            "contains": {
              "type": "object",
              "required": ["routes"],
              "properties": {
                "routes": {
                  "contains": {
                    "type": "object",
                    "required": ["delivery"],
                    "properties": {
                      "delivery": {
                        "type": "object",
                        "required": ["backend"],
                        "properties": {
                          "backend": { "const": "notification_service" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "required": ["repositories"]
      },
      "then": { "required": ["notification_service"] }
    }
  ],
  "$defs": {
    "routeRecordId": {
      "description": "Read-only route record identity derived from canonical repository and persisted idempotency key; it is never accepted in watch config.",
      "type": "string",
      "readOnly": true,
      "pattern": "^[0-9a-f]{64}$"
    },
    "notificationService": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint", "credential_ref", "expected_deployment_digest"],
      "properties": {
        "endpoint": { "type": "string", "format": "uri", "minLength": 1 },
        "credential_ref": {
          "type": "string",
          "pattern": "^(env:[A-Z][A-Z0-9_]*|keychain:[A-Za-z0-9][A-Za-z0-9._-]{0,127}/[A-Za-z0-9][A-Za-z0-9@._-]{0,127})$"
        },
        "expected_deployment_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "allow_insecure_loopback": { "type": "boolean", "default": false }
      },
      "oneOf": [
        {
          "properties": {
            "endpoint": {
              "pattern": "^https://[^/?#@]+/?$"
            }
          }
        },
        {
          "required": ["allow_insecure_loopback"],
          "properties": {
            "endpoint": {
              "pattern": "^http://(?:localhost|127\\.0\\.0\\.1|\\[::1\\])(?::[0-9]+)?/?$"
            },
            "allow_insecure_loopback": { "const": true }
          }
        }
      ]
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "repo", "events"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "events": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "issues.opened",
              "issues.reopened",
              "issues.labeled",
              "push",
              "pull_request.opened",
              "pull_request.synchronize",
              "pull_request.reopened",
              "pull_request.closed",
              "pull_request.ready_for_review",
              "pull_request_review.submitted",
              "pull_request_review.dismissed",
              "check_run.completed",
              "check_suite.completed"
            ]
          }
        },
        "labels": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "include": { "$ref": "#/$defs/uniqueStrings" },
            "exclude": { "$ref": "#/$defs/uniqueStrings" }
          }
        },
        "routes": {
          "type": "array",
          "items": { "$ref": "#/$defs/route" }
        },
        "auto_claim": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "agent_ids": { "$ref": "#/$defs/uniqueStrings" }
          }
        }
      }
    },
    "uniqueStrings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sink", "delivery"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z](?:[a-z0-9-]{0,62}[a-z0-9])?$"
        },
        "sink": { "enum": ["console", "slack", "webhook"] },
        "channel": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "delivery": { "$ref": "#/$defs/delivery" }
      },
      "allOf": [
        {
          "if": { "properties": { "sink": { "const": "console" } }, "required": ["sink"] },
          "then": {
            "properties": {
              "delivery": {
                "allOf": [
                  { "$ref": "#/$defs/delivery" },
                  { "properties": { "backend": { "const": "local" } } }
                ]
              }
            },
            "not": { "required": ["channel"] }
          }
        },
        {
          "if": { "properties": { "sink": { "const": "slack" } }, "required": ["sink"] },
          "then": {
            "required": ["channel"],
            "properties": {
              "delivery": {
                "allOf": [
                  { "$ref": "#/$defs/delivery" },
                  {
                    "properties": {
                      "backend": { "enum": ["direct", "notification_service"] }
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "if": { "properties": { "sink": { "const": "webhook" } }, "required": ["sink"] },
          "then": {
            "not": { "required": ["channel"] },
            "properties": {
              "delivery": {
                "allOf": [
                  { "$ref": "#/$defs/delivery" },
                  {
                    "properties": {
                      "backend": { "enum": ["direct", "notification_service"] }
                    }
                  }
                ]
              }
            }
          }
        }
      ]
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "routing_epoch"],
      "properties": {
        "backend": { "enum": ["local", "direct", "notification_service"] },
        "routing_epoch": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "vendor_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9-]{1,64}$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "backend": { "const": "notification_service" } },
            "required": ["backend"]
          },
          "then": { "required": ["vendor_id"] },
          "else": { "not": { "required": ["vendor_id"] } }
        }
      ]
    }
  }
}
