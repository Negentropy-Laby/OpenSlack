{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openslack.dev/schemas/notification-handoff-v2.schema.json",
  "title": "NotificationHandoffContractsV2",
  "$defs": {
    "routeRecordId": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "idempotencyKey": {
      "type": "string",
      "pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-5[a-f0-9]{3}-[89ab][a-f0-9]{3}-[a-f0-9]{12}$"
    },
    "acceptedEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "data"],
      "properties": {
        "request_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["notification_id", "state", "accepted_at", "idempotent_replay"],
          "properties": {
            "notification_id": { "type": "string", "minLength": 1 },
            "state": { "const": "pending" },
            "accepted_at": { "type": "string", "format": "date-time" },
            "idempotent_replay": { "type": "boolean" }
          }
        }
      }
    },
    "acceptanceLedger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "route_record_id",
        "canonical_repository",
        "route_id",
        "routing_epoch",
        "vendor_id",
        "idempotency_key",
        "notification_id",
        "remote_request_id",
        "accepted_at",
        "idempotent_replay",
        "deployment_digest",
        "watch_config_digest",
        "recorded_at"
      ],
      "properties": {
        "schema": { "const": "openslack.notification_acceptance.v1" },
        "route_record_id": { "$ref": "#/$defs/routeRecordId" },
        "canonical_repository": {
          "type": "string",
          "pattern": "^[^/\\s]+/[^/\\s]+$"
        },
        "route_id": {
          "type": "string",
          "pattern": "^[a-z](?:[a-z0-9-]{0,62}[a-z0-9])?$"
        },
        "routing_epoch": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "vendor_id": { "type": "string", "pattern": "^[a-z0-9-]{1,64}$" },
        "idempotency_key": { "$ref": "#/$defs/idempotencyKey" },
        "notification_id": { "type": "string", "minLength": 1 },
        "remote_request_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "accepted_at": { "type": "string", "format": "date-time" },
        "idempotent_replay": { "type": "boolean" },
        "deployment_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "watch_config_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "recorded_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
