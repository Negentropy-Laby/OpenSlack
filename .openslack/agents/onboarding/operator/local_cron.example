# Local Cron Example — operator
# Add to crontab: crontab -e
# Runs every 15 minutes, off-peak minutes

# OpenSlack Agent Tick — operator
*/15 * * * * cd D:\Users\Administrator\Desktop\OpenSlack && openslack workspace validate && openslack agent tick --agent-id operator --source local-cron >> .openslack/audit/tick.log 2>&1
