# Local Cron Example — {{AGENT_ID}}
# Add to crontab: crontab -e
# Runs every 15 minutes, off-peak minutes

# OpenSlack Agent Tick — {{AGENT_ID}}
*/15 * * * * cd {{WORKSPACE_ROOT}} && openslack workspace validate && openslack agent tick --agent-id {{AGENT_ID}} --source local-cron >> .openslack/audit/tick.log 2>&1
